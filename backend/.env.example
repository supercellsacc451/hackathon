GROQ_API_KEY=
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=40
MODEL_DISCOVERY_TTL_SECONDS=900

# Optional overrides
GROQ_REASONING_MODEL=
GROQ_SAFETY_MODEL=

# Candidate model preference order (comma separated)
GROQ_REASONING_CANDIDATES=openai/gpt-oss-120b,llama-3.3-70b-versatile,openai/gpt-oss-20b,llama-3.1-8b-instant
GROQ_SAFETY_CANDIDATES=openai/gpt-oss-safeguard-20b,openai/gpt-oss-20b,llama-3.1-8b-instant

MIN_WORDS_REQUIRED=25
